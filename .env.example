# ─────────────────────────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────────────────────────
# PostgreSQL (produção) — Neon, Supabase, Vercel Postgres, etc.
# Formato: postgresql://USUARIO:SENHA@HOST/BANCO?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/gestor_rpps?sslmode=require"

# ─────────────────────────────────────────────────────────────────
# AUTENTICAÇÃO (NextAuth v5)
# ─────────────────────────────────────────────────────────────────
# Gere um valor aleatório forte: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-um-segredo-forte-de-pelo-menos-32-caracteres"

# URL pública do app (sem barra final). Em produção use o domínio Vercel.
NEXTAUTH_URL="http://localhost:3001"

# Necessário em deploys atrás de proxy (Vercel, Cloudflare, etc.)
AUTH_TRUST_HOST=true

# ─────────────────────────────────────────────────────────────────
# SEED INICIAL (admin do sistema)
# ─────────────────────────────────────────────────────────────────
# Rode: npm run prisma:seed
SEED_ADMIN_EMAIL="gestor@exemplo.gov.br"
SEED_ADMIN_PASSWORD="troque-em-producao"
