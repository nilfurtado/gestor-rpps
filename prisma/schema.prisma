generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Orgao {
  id               Int                   @id @default(autoincrement())
  nome             String
  sigla            String                @unique
  cnpj             String?
  cep              String?
  endereco         String?
  numero           String?
  complemento      String?
  bairro           String?
  cidade           String?
  estado           String?
  cor              String?
  status           OrgaoStatus           @default(ATIVO)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  razaoSocial      String?
  acordos          Acordo[]
  folhas_pagamento folhas_pagamento[]
  lancamentos      FolhaPrevidenciaria[]

  @@map("orgaos")
}

model Exercicio {
  id          Int                   @id @default(autoincrement())
  ano         Int                   @unique
  status      ExercicioStatus       @default(ABERTO)
  createdAt   DateTime              @default(now())
  lancamentos FolhaPrevidenciaria[]

  @@map("exercicios")
}

model Competencia {
  id               Int                   @id @default(autoincrement())
  mes              String
  ordem            Int                   @unique
  folhas_pagamento folhas_pagamento[]
  lancamentos      FolhaPrevidenciaria[]

  @@map("competencias")
}

model FolhaPrevidenciaria {
  id                     Int                 @id @default(autoincrement())
  orgaoId                Int
  tipo                   TipoContribuicao
  exercicioId            Int
  competenciaId          Int
  aliquota               Decimal
  valorRecolher          Decimal
  valorRecolherCalculado Decimal             @default(0)
  valorRecolhido         Decimal
  quantidadeServidores   Int?
  folhaBase              Decimal?
  multas                 Decimal?            @default(0)
  juros                  Decimal?            @default(0)
  acrescimo              Decimal?            @default(0)
  acrescimo_tipo         TipoAcrescimo       @default(QUITADO)
  parcelado              Boolean             @default(false)
  deficit                Decimal
  superavit              Decimal             @default(0)
  inadimplencia          Decimal
  percentualPago         Decimal             @default(0)
  valorTotalDevido       Decimal             @default(0)
  encargosTotal          Decimal             @default(0)
  valorLiquidoArrecadado Decimal             @default(0)
  status                 LancamentoStatus
  responsavelId          Int?
  dataVencimento         DateTime?
  observacoes            String?
  justificativaDiferenca String?
  diferenca_aprovada     Boolean             @default(false)
  dataAprovacao          DateTime?
  usuarioAprovadorId     Int?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  folhaSuplementar       Decimal?            @default(0)
  numeroGuia             String?             @unique
  dataEmissao            DateTime?
  usuarioAprovador       User?               @relation("AprovadasPor", fields: [usuarioAprovadorId], references: [id])
  responsavel            User?               @relation(fields: [responsavelId], references: [id])
  competencia            Competencia         @relation(fields: [competenciaId], references: [id])
  exercicio              Exercicio           @relation(fields: [exercicioId], references: [id])
  orgao                  Orgao               @relation(fields: [orgaoId], references: [id])
  folhasSupplementares   FolhaSupplementar[] @relation("FolhaPrevidenciariaSupplementares")
  acordos                Acordo[]            @relation("AcordoLancamentos")
  folhas                 LancamentoFolha[]   @relation("folhas")
  folhaTotal             Decimal?            @default(0)
  totalARecolher         Decimal?            @default(0)
  totalRecolhido         Decimal?            @default(0)
  deficitTotal           Decimal?            @default(0)

  @@unique([orgaoId, tipo, exercicioId, competenciaId])
  @@index([exercicioId, competenciaId])
  @@index([status])
  @@map("folhas_previdenciarias")
}

model FolhaSupplementar {
  id                     Int                 @id @default(autoincrement())
  folhaPrevidenciariaId  Int
  numeroComplementacao   String
  tipoComplementacao     String
  valorFolhaComplementar Decimal
  aliquota               Decimal
  contribuicaoDevida     Decimal
  valorRecolhido         Decimal?
  dataRepasse            DateTime?
  descricao              String?
  observacoes            String?
  multas                 Decimal?
  juros                  Decimal?
  status                 LancamentoStatus    @default(LANCADO)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  folhaPrevidenciaria    FolhaPrevidenciaria @relation("FolhaPrevidenciariaSupplementares", fields: [folhaPrevidenciariaId], references: [id], onDelete: Cascade)

  @@unique([folhaPrevidenciariaId, numeroComplementacao])
  @@index([folhaPrevidenciariaId])
  @@index([status])
  @@index([tipoComplementacao])
  @@map("folhas_suplementares")
}

model User {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique
  nome                String
  passwordHash        String
  role                Role                  @default(OPERADOR)
  createdAt           DateTime              @default(now())
  acordos             Acordo[]
  arrecadacoes        arrecadacoes[]
  folhas_pagamento    folhas_pagamento[]
  diferencasAprovadas FolhaPrevidenciaria[] @relation("AprovadasPor")
  lancamentos         FolhaPrevidenciaria[]

  @@map("users")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  entityType String
  entityId   Int
  action     String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model InstitutoRpps {
  id                      Int       @id @default(autoincrement())
  nomeInstituto           String?
  nomeResponsavel         String?
  cnpj                    String?
  enderecoCompleto        String?
  telefone                String?
  email                   String?
  nomeDepartamento        String?
  responsavelDepartamento String?
  logoPath                String?
  logoData                Bytes?
  logoMime                String?
  banco                   String?
  agencia                 String?
  conta                   String?
  tipoConta               String?
  updatedAt               DateTime  @updatedAt
  barcodeFebraban         String?
  ultimoBarcodeGerado     DateTime?

  @@map("instituto_rpps")
}

model Acordo {
  id                   Int                   @id @default(autoincrement())
  numero               String
  dataAcordo           DateTime
  orgaoId              Int
  tipoDebito           TipoDebitoAcordo
  valorOriginal        Decimal
  atualizacaoMonetaria Decimal               @default(0)
  jurosAcordo          Decimal               @default(0)
  multaAcordo          Decimal               @default(0)
  valorConsolidado     Decimal
  numeroParcelas       Int
  valorParcela         Decimal
  diaVencimento        Int
  primeiroVencimento   DateTime
  parcelasPagas        Int                   @default(0)
  valorPago            Decimal               @default(0)
  status               StatusAcordo          @default(VIGENTE)
  formaGarantia        FormaGarantia?
  garantiaDetalhes     String?
  leiAutorizativa      String?
  observacoes          String?
  responsavelId        Int
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  responsavel          User                  @relation(fields: [responsavelId], references: [id])
  orgao                Orgao                 @relation(fields: [orgaoId], references: [id])
  lancamentos          FolhaPrevidenciaria[] @relation("AcordoLancamentos")

  @@unique([orgaoId, numero])
  @@index([status])
  @@index([orgaoId, status])
  @@map("acordos")
}

model TipoFolha {
  id               Int               @id @default(autoincrement())
  nome             String            @unique
  descricao        String?
  ordem            Int               @default(0)
  obrigatorio      Boolean           @default(false)
  customizado      Boolean           @default(false)
  ativo            Boolean           @default(true)
  cor              String?           @default("text-blue-600")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  lancamentoFolhas LancamentoFolha[]

  @@index([nome])
  @@map("tipos_folha")
}

model LancamentoFolha {
  id             Int                 @id @default(autoincrement())
  lancamentoId   Int
  lancamento     FolhaPrevidenciaria @relation("folhas", fields: [lancamentoId], references: [id], onDelete: Cascade)
  tipoFolhaId    Int
  tipoFolha      TipoFolha           @relation(fields: [tipoFolhaId], references: [id])

  valor          Decimal
  aliquota       Decimal
  valorARecolher Decimal
  valorRecolhido Decimal
  diferenca      Decimal

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([lancamentoId, tipoFolhaId])
  @@index([lancamentoId])
  @@map("lancamento_folhas")
}

model BackupMetadata {
  id          String   @id @default(cuid())
  backupId    String   @unique
  filename    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("backup_metadata")
}

model arrecadacoes {
  id                        Int              @id @default(autoincrement())
  folhaPagamentoId          Int
  numeroLancamento          String
  dataLancamento            DateTime
  folhaBase                 Decimal
  folhaSuplementer          Decimal          @default(0)
  folhaComplementar         Decimal          @default(0)
  folhaTotal                Decimal
  baseServidor              Decimal
  basePatronal              Decimal
  baseSuplementer           Decimal          @default(0)
  aliquotaServidor          Decimal
  aliquotaPatronal          Decimal
  aliquotaSuplementer       Decimal          @default(0)
  contribuicaoServidor      Decimal
  contribuicaoPatronal      Decimal
  contribuicaoSuplementer   Decimal          @default(0)
  totalDevido               Decimal
  valorRecolhidoServidor    Decimal
  valorRecolhidoPatronal    Decimal
  valorRecolhidoSuplementer Decimal          @default(0)
  totalRecolhido            Decimal
  diferencaServidor         Decimal
  diferencaPatronal         Decimal
  diferencaSuplementer      Decimal          @default(0)
  diferencaTotal            Decimal
  observacao                String?
  status                    String           @default("RASCUNHO")
  usuarioId                 Int?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime
  users                     User?            @relation(fields: [usuarioId], references: [id])
  folhas_pagamento          folhas_pagamento @relation(fields: [folhaPagamentoId], references: [id])

  @@unique([folhaPagamentoId, numeroLancamento])
  @@index([dataLancamento])
  @@index([status])
  @@index([folhaPagamentoId])
}

model folhas_pagamento {
  id                     Int            @id @default(autoincrement())
  orgaoId                Int
  competenciaId          Int
  tipoFolha              String
  numeroFolha            String
  descricao              String?
  dataReferencia         DateTime
  folhaBase              Decimal?
  folhaSuplementer       Decimal?
  folhaComplementar      Decimal?
  folha13                Decimal?
  folhaRescisao          Decimal?
  folhaRetroativa        Decimal?
  folhaTotal             Decimal        @default(0)
  quantidadeServidores   Int?
  valorTotalContribuicao Decimal        @default(0)
  aliquotaServidor       Decimal?
  valorServidor          Decimal?
  aliquotaPatronal       Decimal?
  valorPatronal          Decimal?
  aliquotaSuplementer    Decimal?
  valorSuplementer       Decimal?
  dataImportacao         DateTime       @default(now())
  origem                 String?
  hashArquivo            String?
  nomeArquivo            String?
  usuarioImportacaoId    Int?
  status                 String         @default("IMPORTADA")
  observacao             String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime
  arrecadacoes           arrecadacoes[]
  users                  User?          @relation(fields: [usuarioImportacaoId], references: [id])
  competencias           Competencia    @relation(fields: [competenciaId], references: [id])
  orgaos                 Orgao          @relation(fields: [orgaoId], references: [id])

  @@unique([orgaoId, competenciaId, tipoFolha, numeroFolha])
  @@index([tipoFolha])
  @@index([status])
  @@index([competenciaId])
  @@index([orgaoId])
}

enum OrgaoStatus {
  ATIVO
  INATIVO
}

enum ExercicioStatus {
  ABERTO
  ENCERRADO
}

enum TipoContribuicao {
  PATRONAL
  SEGURADO
}

enum LancamentoStatus {
  PAGO
  PARCIAL
  INADIMPLENTE
  PARCELADO
  SEM_MOVIMENTO
  LANCADO
  RECOLHIMENTO_A_MAIOR
}

enum TipoAcrescimo {
  ACRESCIMO
  DIFERENCA
  QUITADO
}

enum Role {
  GESTOR
  OPERADOR
}

enum TipoDebitoAcordo {
  PATRONAL
  SEGURADO
  AMBOS
}

enum FormaGarantia {
  FPM
  CAUC
  RECEITAS_PROPRIAS
  OUTRA
}

enum StatusAcordo {
  VIGENTE
  QUITADO
  RESCINDIDO
  SUSPENSO
}
