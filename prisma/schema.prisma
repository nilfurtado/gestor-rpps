generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Orgao {
  id           Int                    @id @default(autoincrement())
  nome         String
  sigla        String                 @unique
  razaoSocial  String?                // Razão Social (opcional)
  cnpj         String?
  cep          String?
  endereco     String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  cor          String?                // HEX color #RRGGBB usado em gráficos
  status       OrgaoStatus            @default(ATIVO)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  lancamentos  FolhaPrevidenciaria[]
  acordos      Acordo[]

  @@map("orgaos")
}

model Exercicio {
  id          Int                    @id @default(autoincrement())
  ano         Int                    @unique
  status      ExercicioStatus        @default(ABERTO)
  createdAt   DateTime               @default(now())
  lancamentos FolhaPrevidenciaria[]

  @@map("exercicios")
}

model Competencia {
  id          Int                    @id @default(autoincrement())
  mes         String
  ordem       Int                    @unique
  lancamentos FolhaPrevidenciaria[]

  @@map("competencias")
}

model FolhaPrevidenciaria {
  id                      Int              @id @default(autoincrement())
  orgaoId                 Int
  orgao                   Orgao            @relation(fields: [orgaoId], references: [id])
  tipo                    TipoContribuicao
  exercicioId             Int
  exercicio               Exercicio        @relation(fields: [exercicioId], references: [id])
  competenciaId           Int
  competencia             Competencia      @relation(fields: [competenciaId], references: [id])
  aliquota                Decimal
  valorRecolher           Decimal
  valorRecolherCalculado  Decimal          @default(0) // Folha Base × Alíquota ÷ 100
  valorRecolhido          Decimal
  quantidadeServidores    Int?
  folhaBase               Decimal?
  multas                  Decimal?        @default(0)
  juros                   Decimal?        @default(0)
  acrescimo               Decimal?        @default(0)
  acrescimo_tipo          TipoAcrescimo   @default(QUITADO)
  parcelado               Boolean         @default(false)
  deficit                 Decimal
  superavit               Decimal         @default(0)        // Valor Recolhido > Valor a Recolher
  inadimplencia           Decimal
  percentualPago          Decimal         @default(0)        // % de quitação
  valorTotalDevido        Decimal         @default(0)        // Deficit + Multas + Juros
  encargosTotal           Decimal         @default(0)        // Multas + Juros
  valorLiquidoArrecadado  Decimal         @default(0)        // Recolhido - Multas - Juros
  status                  LancamentoStatus
  responsavelId           Int?
  responsavel             User?           @relation(fields: [responsavelId], references: [id])
  dataVencimento          DateTime?
  observacoes             String?
  acordos                 Acordo[]        @relation("AcordoLancamentos")
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@unique([orgaoId, tipo, exercicioId, competenciaId])
  @@index([exercicioId, competenciaId])
  @@index([status])
  @@map("folhas_previdenciarias")
}

model User {
  id           Int                    @id @default(autoincrement())
  email        String                 @unique
  nome         String
  passwordHash String
  role         Role                   @default(OPERADOR)
  createdAt    DateTime               @default(now())
  lancamentos  FolhaPrevidenciaria[]
  acordos      Acordo[]

  @@map("users")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  entityType String
  entityId   Int
  action     String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model InstitutoRpps {
  id                      Int      @id @default(1)
  nomeInstituto           String?
  nomeResponsavel         String?
  cnpj                    String?
  enderecoCompleto        String?
  telefone                String?
  email                   String?
  nomeDepartamento        String?
  responsavelDepartamento String?
  logoPath                String?
  logoData                Bytes?   // logo armazenado diretamente no banco (Postgres bytea)
  logoMime                String?  // ex.: image/jpeg, image/png
  banco                   String?  // Nome ou código do banco (ex: 001 - Banco do Brasil)
  agencia                 String?  // Número da agência
  conta                   String?  // Número da conta
  tipoConta               String?  // Tipo da conta (Corrente, Poupança, etc)
  updatedAt               DateTime @updatedAt

  @@map("instituto_rpps")
}

enum OrgaoStatus {
  ATIVO
  INATIVO
}

enum ExercicioStatus {
  ABERTO
  ENCERRADO
}

enum TipoContribuicao {
  PATRONAL
  SEGURADO
}

enum LancamentoStatus {
  PAGO
  PARCIAL
  INADIMPLENTE
  PARCELADO
  SEM_MOVIMENTO
  RECOLHIMENTO_A_MAIOR
}

enum TipoAcrescimo {
  ACRESCIMO
  DIFERENCA
  QUITADO
}

enum Role {
  GESTOR
  OPERADOR
  AUDITOR
}

enum TipoDebitoAcordo {
  PATRONAL
  SEGURADO
  AMBOS
}

enum FormaGarantia {
  FPM
  CAUC
  RECEITAS_PROPRIAS
  OUTRA
}

enum StatusAcordo {
  VIGENTE
  QUITADO
  RESCINDIDO
  SUSPENSO
}

model Acordo {
  id                   Int      @id @default(autoincrement())
  numero               String
  dataAcordo           DateTime
  orgaoId              Int
  orgao                Orgao    @relation(fields: [orgaoId], references: [id])
  tipoDebito           TipoDebitoAcordo

  valorOriginal        Decimal
  atualizacaoMonetaria Decimal  @default(0)
  jurosAcordo          Decimal  @default(0)
  multaAcordo          Decimal  @default(0)
  valorConsolidado     Decimal

  numeroParcelas       Int
  valorParcela         Decimal
  diaVencimento        Int
  primeiroVencimento   DateTime

  parcelasPagas        Int      @default(0)
  valorPago            Decimal  @default(0)
  status               StatusAcordo @default(VIGENTE)

  formaGarantia        FormaGarantia?
  garantiaDetalhes     String?
  leiAutorizativa      String?
  observacoes          String?

  responsavelId        Int
  responsavel          User     @relation(fields: [responsavelId], references: [id])

  lancamentos          FolhaPrevidenciaria[] @relation("AcordoLancamentos")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([orgaoId, numero])
  @@index([status])
  @@index([orgaoId, status])
  @@map("acordos")
}
